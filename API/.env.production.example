APP_DOMAIN=app.seudominio.com
VITE_API_URL=https://app.seudominio.com/api/v1
PUBLIC_API_BASE_URL=https://app.seudominio.com

# CORS: so precisa listar dominios reais se o frontend consumir a API por outro host.
CORS_ALLOW_ORIGINS=https://app.seudominio.com
CORS_ALLOW_ORIGIN_REGEX=

# Banco existente fora do Docker.
# Se o PostgreSQL estiver no mesmo Ubuntu, use host.docker.internal.
# Se estiver em outro servidor, informe o IP ou hostname real.
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=troque-esta-senha
DB_NAME=Contratos

JWT_SECRET_KEY=troque-esta-chave-forte
SECRET_ENCRYPTION_KEY=troque-esta-chave-forte
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

QUEPASA_APIWPP_URL=https://apiwpp.vstec.net
QUEPASA_MIDDLEWARE_URL=http://middleware.vstec.net
QUEPASA_USER=
QUEPASA_TOKEN=CONTRATOS
QUEPASA_HEALTH_PASSWORD=troque-esta-chave-forte
QUEPASA_TIMEOUT_SECONDS=15
